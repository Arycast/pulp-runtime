RM ?= rm --verbose -f

.PHONY: all run clean

all: main

# build the tester
main: main.c ../../debugger_writer.c
	#$(CC) $(CFLAGS) -g -Wall -Wextra -pedantic -Wconversion -std=c11 $(LDFLAGS) -DDEBUGGER_DATA_BLOCK_SIZE=16 -o $@ $^ $(LIBS)
	$(CC) $(CFLAGS) -g -Wall -Wextra -pedantic -Wconversion -std=c11 $(LDFLAGS) -o $@ $^ $(LIBS)

clean:
	$(RM) main

# use make run to test writing n bytes to buffer array, data is random byte generated by /dev/random
run: main
	sh -c 'CONTENT=$$(mktemp) && \
		head --bytes="$$2" "/dev/random" > "$$CONTENT" && \
		GDBINIT="$$(mktemp)" && \
		echo "break INTERRUPT_HERE_TO_OVERWRITE_DATA_TO_SEND_TO_FLASH" >> "$$GDBINIT" && \
		echo "run" >> "$$GDBINIT" && \
		echo "restore $$CONTENT binary buffer" >> "$$GDBINIT" && \
		echo "set *buffer_fill_length=$$2" >> "$$GDBINIT" && \
		echo "continue" >> "$$GDBINIT" && \
		echo "quit" >> "$$GDBINIT" && \
		gdb -x "$$GDBINIT" "$$1" && \
		rm --verbose "$$CONTENT" "$$GDBINIT"' -- $< 12
